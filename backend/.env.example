NODE_ENV=development
PORT=5000

# MongoDB
# URL-encode special characters in credentials (for example @ as %40)
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/collab_analytics?retryWrites=true&w=majority
MONGO_MAX_RETRIES=5
MONGO_RETRY_DELAY_MS=2000
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=5
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_HEARTBEAT_FREQUENCY_MS=10000

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_ACCESS_SECRET=replace_this_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_this_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
