NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-netlify-app.netlify.app
CORS_ORIGIN=https://your-netlify-app.netlify.app
MONGO_URI=mongodb+srv://<db_user>:<url_encoded_password>@<cluster>.mongodb.net/collab_analytics_db?retryWrites=true&w=majority
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
